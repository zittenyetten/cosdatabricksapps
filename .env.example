DATABRICKS_HOST=https://<workspace-host>
DATABRICKS_SERVER_HOSTNAME=<workspace-host-without-scheme>

# Databricks Apps maps the SQL warehouse resource key `sql-warehouse` to this env var.
DATABRICKS_WAREHOUSE_ID=<warehouse-id>

# Local fallback if you do not use a Databricks Apps SQL warehouse resource.
# DATABRICKS_HTTP_PATH=/sql/1.0/warehouses/<warehouse-id>

# Databricks Apps injects these automatically for app authorization.
DATABRICKS_CLIENT_ID=<app-oauth-client-id>
DATABRICKS_CLIENT_SECRET=<app-oauth-client-secret>

# Local development fallback only. Do not use PAT in production.
# DATABRICKS_TOKEN=<personal-access-token>

RBAC_RAG_CATALOG=cos_adb
RBAC_RAG_TOP_K_DEFAULT=5
